# Optional override for permit API (defaults to https://fastview-sdci.onrender.com)
# VITE_SDCI_API_BASE=https://fastview-sdci.onrender.com

# Set to true for vite preview / special setups so /health uses same-origin proxy (/sdci-api -> Render).
# Dev server enables this automatically via import.meta.env.DEV.
# VITE_SDCI_PROXY=true
