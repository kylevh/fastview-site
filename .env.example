# Canonical / social preview base URL (no trailing slash). Defaults to the Vercel project URL; set
# this when you use a custom domain so meta tags, sitemap, and JSON-LD stay correct in production.
# VITE_PUBLIC_SITE_URL=https://fastview-site.vercel.app

# Optional override for permit API (defaults to https://fastview-sdci.onrender.com)
# VITE_SDCI_API_BASE=https://fastview-sdci.onrender.com

# Production: prefer leaving this unset — `fetchPermitApiHealth` retries same-origin `/sdci-api/health`
# when cross-origin `/health` fails (CORS). Ship `public/_redirects` (Netlify) or `vercel.json` (Vercel).
#
# Set to true if your host does NOT proxy `/sdci-api/*` but your API sends correct CORS for `/health`
# (unusual). Dev uses `/sdci-api` automatically (no env needed).
# VITE_SDCI_PROXY=true
